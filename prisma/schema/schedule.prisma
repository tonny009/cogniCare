model Schedule{
    id          String   @id @default(uuid())
    startDateTime DateTime
    endDateTime   DateTime
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    doctorSChedules DoctorSchedules[] //for below connections with DoctorSchedules model
    @@map("schedules")  
}

model DoctorSchedules{
    doctorId    String
    scheduleId  String
    isBooked    Boolean  @default(false)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    doctor      Doctor     @relation(fields: [doctorId], references: [id]) // go to doctor model and check the extension
    schedule    Schedule @relation(fields: [scheduleId], references: [id])

    @@id([doctorId, scheduleId]) //Used composite key : these 2 id together create a primary key 
    @@map("doctor_schedules")  
}